{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "./@types"],
    "types": ["node"]
  },
  "include": ["agent/**/*", "scripts/**/*", "test/**/*", "@types/**/*"],
  "exclude": ["node_modules", "dist", "frontend"]
}
